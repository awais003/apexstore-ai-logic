import json

def generate_tags(product_text):
    # Predefined list of possible tags
    tags = ["wireless", "bluetooth", "electronics", "smartphone", "gadget", "accessory"]

    # Initialize an empty list to store the generated tags
    generated_tags = []

    # Loop through the possible tags
    for tag in tags:
        # Check if the tag is present in the product text
        if tag.lower() in product_text.lower():
            # If the tag is present, add it to the generated tags list
            generated_tags.append(tag)

    # Limit the generated tags to 5
    generated_tags = generated_tags[:5]

    # Return the generated tags as a JSON object
    return json.dumps({
        "product_id": 1,
        "tags": generated_tags
    })

# Example usage:
product_text = "This is a wireless Bluetooth smartphone accessory."
print(generate_tags(product_text))
